# Copy to .env and adjust. In production these MUST be set.
# Config is loaded and validated at startup by config.py (pydantic-settings).

# Environment isolation: development | staging | production.
# In production the app refuses to start without JWT_SECRET_KEY.
APP_ENV=development

# Secret used to sign JWT access tokens. Generate a strong random value:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=

# Key rotation: comma-separated PREVIOUS keys still accepted when verifying
# tokens, so you can rotate JWT_SECRET_KEY with zero downtime.
JWT_PREVIOUS_KEYS=

# Minutes until an access token expires.
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Comma-separated allowed CORS origins (web clients only).
CORS_ORIGINS=http://localhost:8081,http://localhost:19006

# SQLAlchemy database URL.
DATABASE_URL=sqlite:///./biostock.db
