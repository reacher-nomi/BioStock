# Copy to .env and adjust. In production these MUST be set.

# App environment: "development" or "production".
# When "production", the app refuses to start without JWT_SECRET_KEY.
APP_ENV=development

# Secret used to sign JWT access tokens. Generate a strong random value, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=

# Comma-separated list of allowed CORS origins (web clients only).
CORS_ORIGINS=http://localhost:8081,http://localhost:19006
